<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Server URL (https://your-server:8080)"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/deviceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device ID (e.g. pixel-8)"
            android:inputType="text" />

        <EditText
            android:id="@+id/token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device token"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/aesKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AES key (base64)"
            android:inputType="textPassword" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Email (IMAP) — optional, add one or more"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/accountsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="No mailboxes configured"
            android:textStyle="italic" />

        <EditText
            android:id="@+id/imapHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IMAP host (e.g. imap.gmail.com)"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/imapPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IMAP port (default 993)"
            android:inputType="number" />

        <EditText
            android:id="@+id/imapUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IMAP user (email address)"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/imapPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IMAP password (or app password)"
            android:inputType="textPassword" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/addMailboxButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Add mailbox" />

            <Button
                android:id="@+id/clearMailboxesButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear" />
        </LinearLayout>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save &amp; enable capture" />

        <Button
            android:id="@+id/notificationAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant notification access" />

    </LinearLayout>
</ScrollView>
